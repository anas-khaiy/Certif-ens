% Bibliography settings - Custom Numeric Style
\usepackage[backend=biber, style=numeric, sorting=none, isbn=false, doi=false]{biblatex}
\addbibresource{references.bib}

% Remove "In:" for articles
\renewbibmacro{in:}{}

% Format titles with standard LaTeX quotes
\DeclareFieldFormat{title}{``#1''}
\DeclareFieldFormat[article]{title}{``#1''}
\DeclareFieldFormat[book]{title}{``#1''}
\DeclareFieldFormat[misc]{title}{``#1''}
\DeclareFieldFormat[online]{title}{``#1''}

% Author format: S. Nacih (given name as initial)
\DeclareNameAlias{default}{given-family}

% robust line break for URLs in the bibliography
\newcommand{\robustnewline}{\hfill\break}
\DeclareFieldFormat{url}{\addcomma\robustnewline url : \url{#1}}

% Year at the end of the main line
\renewbibmacro*{date}{\printfield{year}}
\renewbibmacro*{issue+date}{\printfield{year}}

% Punctuation and units
\renewcommand*{\newunitpunct}{\addcomma\addspace}
\renewcommand*{\labelnamepunct}{\addcomma\addspace}

\renewcommand{\bibname}{References}

% List management
\setlist[itemize,1]{label=$\bullet$}
\setlist[itemize,2]{label=--}
\setlist[itemize,3]{label=$\ast$}
\setlist[itemize,4]{label=$\circ$}

% Custom environments for glossaries if needed
\newenvironment{abbrv}{\begin{itemize}[label=]}{\end{itemize}}
